# 推荐优先尝试兼容接口。若网关返回 192.168.x.x 等客户端不可达的内网图片 URL，
# 临时把 provider 改为 direct；语义分组仍继续复用 LP_COMPAT_*。
LP_IMAGE_PROVIDER=chat_compat
LP_COMPAT_BASE_URL=https://test-plugin.longpean.com/v1/chat/completions
LP_COMPAT_TOKEN=

# 备用：Codex gpt-image-2 插件直连接口。参考图必须先上传成远端 HTTP URL。
LP_IMAGE_DIRECT_URL=https://gptapi.longpean.com/gptImage/generateImageDirect
LP_IMAGE_UPLOAD_URL=https://stpic.longpean.com/picture/upLoadQiNiu
LP_IMAGE_TOKEN=
LP_IMAGE_UPLOAD_TOKEN=
LP_IMAGE_SIZE=auto
LP_IMAGE_TEMPLATE_CODE=WINDOW_STICKER_MVP
LP_OPERATOR_ID=0
LP_OPERATOR_NAME=Window Sticker Workbench

# 可选覆盖；留空时复用 LP_COMPAT_BASE_URL / LP_COMPAT_TOKEN。
LP_VISION_BASE_URL=
LP_VISION_TOKEN=
LP_VISION_MODEL=codex-gpt-5.6-luna

# 旧版 OpenAI 兼容生图 provider，仅在未配置 LP_IMAGE_DIRECT_URL 时使用。
LP_AI_BASE_URL=
LP_AI_TOKEN=
LP_IMAGE_MODEL=gpt-image-2
